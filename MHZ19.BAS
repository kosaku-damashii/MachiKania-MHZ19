REM MHZ19.BAS
CLS
SERIAL 9600
DIM C(2),D(2)
GOSUB AUTOCAL

WHILE 1
 GOSUB GETPPM
 I=0
 DO
  A=SERIALIN()
  IF A<0 THEN CONTINUE
  REM PRINT HEX$(A,2);
  IF I== 2 THEN Q=A*256
  IF I== 3 THEN Q=Q+A
  IF I== 4 THEN T=A-40
  I=I+1
 LOOP UNTIL I>8
 PRINT GETTIME$();
 PRINT "  CO2=";Q;" Temp=";T
 WAIT 5*60
WEND

LABEL AUTOCAL
C(0)=$FF0179A0
C(1)=$00000000
C(2)=$FF-(C AND $FF) << 8*3
FOR I=0 TO 8
 P=GOSUB(GETB,C,I)
 SERIALOUT P
 COLOR 4
 REM PRINT HEX$(P,2);
 COLOR 7
NEXT
PRINT ""
RETURN


LABEL GETPPM
C(0)=$FF018600
C(1)=$00000000
C(2)=$79000000
FOR I=0 TO 8
 P=GOSUB(GETB,C,I)
 SERIALOUT P
 COLOR 4
 REM PRINT HEX$(P,2);
 COLOR 7
NEXT
PRINT ""
RETURN


LABEL GETB
 VAR C,i,p
 C=ARGS(1)
 I=ARGS(2)
 P=(C(I/4) >> 8*(3-(I%4))) AND $FF
RETURN P
